<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.JamsGadget" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryDark</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/colorGold</item>
        <item name="colorSecondaryVariant">@color/colorGoldDark</item>
        <item name="colorOnSecondary">@color/colorPrimary</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/colorPrimary</item>
        <item name="android:windowLightStatusBar">false</item>
        <!-- Navigation bar color. -->
        <item name="android:navigationBarColor">@color/colorPageBg</item>
        <item name="android:windowLightNavigationBar">true</item>

        <item name="android:windowBackground">@color/colorPageBg</item>

        <!-- Default font for the entire app -->
        <item name="android:fontFamily">sans-serif</item>

        <!-- Custom Activity Transitions -->
        <item name="android:windowAnimationStyle">@style/Animation.Jams.Activity</item>

        <!-- Material Components styling -->
        <item name="materialCardViewStyle">@style/Widget.Jams.CardView</item>
        <item name="textInputStyle">@style/Widget.Jams.TextInputLayout</item>
        <item name="materialButtonStyle">@style/Widget.Jams.Button</item>
        <item name="chipStyle">@style/Widget.Jams.Chip</item>
        <item name="floatingActionButtonStyle">@style/Widget.Jams.FAB</item>
    </style>

    <!-- Animation Style -->
    <style name="Animation.Jams.Activity" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/slide_out_left</item>
        <item name="android:activityCloseEnterAnimation">@anim/slide_in_left</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_out_right</item>
    </style>

    <style name="Theme.JamsGadget.Dialog" parent="Theme.MaterialComponents.Light.Dialog.MinWidth">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="Widget.Jams.CardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/colorCardBg</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
        <item name="strokeColor">@color/colorCardBorder</item>
        <item name="strokeWidth">0.5dp</item>
    </style>

    <style name="Widget.Jams.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">10dp</item>
        <item name="boxCornerRadiusTopEnd">10dp</item>
        <item name="boxCornerRadiusBottomStart">10dp</item>
        <item name="boxCornerRadiusBottomEnd">10dp</item>
        <item name="boxStrokeColor">@color/colorGold</item>
        <item name="hintTextColor">@color/colorGold</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="Widget.Jams.Button" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">10dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:height">48dp</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="Widget.Jams.Button.Secondary" parent="Widget.Jams.Button">
        <item name="backgroundTint">@color/colorPageBg</item>
        <item name="android:textColor">@color/colorPrimary</item>
        <item name="strokeColor">@color/colorCardBorder</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.Jams.Chip" parent="Widget.MaterialComponents.Chip.Action">
        <item name="chipBackgroundColor">@color/colorGold</item>
        <item name="android:textColor">@color/colorPrimary</item>
        <item name="chipCornerRadius">8dp</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="Widget.Jams.FAB" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="backgroundTint">@color/colorPrimary</item>
        <item name="tint">@color/colorGold</item>
    </style>

    <style name="ShapeAppearance.Large.TopRounded" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">32dp</item>
        <item name="cornerSizeTopRight">32dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <!-- Splash Screen Theme -->
    <style name="Theme.JamsGadget.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/brand_navy</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/transparent_icon</item>
        <item name="windowSplashScreenAnimationDuration">0</item>
        <item name="postSplashScreenTheme">@style/Theme.JamsGadget</item>
    </style>

    <style name="NavigationViewStyle" parent="Widget.Design.NavigationView">
        <item name="itemIconTint">@color/white</item>
        <item name="itemTextColor">@color/white</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>
</resources>