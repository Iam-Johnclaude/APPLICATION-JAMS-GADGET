<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Active State -->
    <item android:state_checked="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/nav_active_bg" />
                </shape>
            </item>
            <!-- Amber right border indicator -->
            <item android:left="-4dp" android:top="-4dp" android:bottom="-4dp">
                <shape android:shape="rectangle">
                    <stroke android:width="4dp" android:color="@color/brand_amber" />
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- Default State -->
    <item android:drawable="@android:color/transparent" />
</selector>