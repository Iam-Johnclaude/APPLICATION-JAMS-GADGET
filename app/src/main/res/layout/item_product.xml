<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Colored Left Border Accent -->
        <View
            android:id="@+id/viewStatusAccent"
            android:layout_width="6dp"
            android:layout_height="0dp"
            android:background="@color/success"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Product Image -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardImage"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_margin="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:layout_constraintStart_toEndOf="@id/viewStatusAccent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/ivProduct"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_inventory"
                app:tint="@color/brand_navy" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Product Name -->
        <TextView
            android:id="@+id/tvName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Product Name"
            android:textColor="@color/brand_navy"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/tvPrice"
            app:layout_constraintStart_toEndOf="@id/cardImage"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Brand & Condition -->
        <TextView
            android:id="@+id/tvBrandCondition"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Brand • New"
            android:textColor="#64748B"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="@id/tvName"
            app:layout_constraintStart_toStartOf="@id/tvName"
            app:layout_constraintTop_toBottomOf="@id/tvName" />

        <!-- Category Tag -->
        <TextView
            android:id="@+id/tvCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/badge_pill_bg"
            android:backgroundTint="#F1F5F9"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="Category"
            android:textColor="#475569"
            android:textSize="10sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/tvName"
            app:layout_constraintTop_toBottomOf="@id/tvBrandCondition" />

        <!-- Price -->
        <TextView
            android:id="@+id/tvPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="12dp"
            android:text="₱0.00"
            android:textColor="@color/brand_navy"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Quantity Badge -->
        <TextView
            android:id="@+id/tvQuantity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/badge_pill_bg"
            android:backgroundTint="@color/brand_gold"
            android:minWidth="32dp"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="10"
            android:textColor="@color/brand_navy"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"
            app:layout_constraintEnd_toEndOf="@id/tvPrice"
            app:layout_constraintTop_toBottomOf="@id/tvPrice" />

        <!-- Stock Availability Row -->
        <TextView
            android:id="@+id/tvStockLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Stock Availability"
            android:textColor="#64748B"
            android:textSize="11sp"
            app:layout_constraintStart_toStartOf="@id/cardImage"
            app:layout_constraintTop_toBottomOf="@id/cardImage" />

        <TextView
            android:id="@+id/tvStockStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Good Stock"
            android:textColor="@color/success"
            android:textSize="11sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/tvStockLabel"
            app:layout_constraintEnd_toEndOf="@id/tvPrice"
            app:layout_constraintTop_toTopOf="@id/tvStockLabel" />

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/pbStock"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="6dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="12dp"
            android:max="100"
            android:progress="75"
            android:progressTint="@color/success"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="@id/tvStockStatus"
            app:layout_constraintStart_toStartOf="@id/tvStockLabel"
            app:layout_constraintTop_toBottomOf="@id/tvStockLabel" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>