<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="160dp"
    android:background="@color/brand_navy"
    android:gravity="bottom"
    android:orientation="vertical"
    android:padding="24dp"
    android:theme="@style/ThemeOverlay.AppCompat.Dark">

    <TextView
        android:id="@+id/tvNavName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Jams Owner"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvNavEmail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="owner@jamsgadget.com"
        android:textColor="@color/nav_muted_text"
        android:textSize="14sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/badge_pill_bg"
        android:backgroundTint="#2A3545"
        android:paddingHorizontal="8dp"
        android:paddingVertical="2dp"
        android:text="ADMINISTRATOR"
        android:textColor="@color/brand_amber"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"/>

</LinearLayout>